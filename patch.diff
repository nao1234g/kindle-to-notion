diff --git a/scripts/doctor.sh b/scripts/doctor.sh
index 6666666..7777777 100755
--- a/scripts/doctor.sh
+++ b/scripts/doctor.sh
@@
 DB_JSON=$(curl -s -H "Authorization: Bearer $NOTION_TOKEN" \
   -H "Notion-Version: 2022-06-28" \
   https://api.notion.com/v1/databases/$BOOK_DB_ID)
 
-echo "✅  Database reachable"
+echo "✅  Database reachable"
+
+# --- タイトル列存在チェック ------------------------------
+TITLE_KEY=${PROP_TITLE:-Title}
+if ! echo "$DB_JSON" | jq -e ".properties[\"$TITLE_KEY\"].type" >/dev/null; then
+  echo "❌ '$TITLE_KEY' 列が見つかりません"
+  exit 1
+fi
+echo "✅  '$TITLE_KEY' 列を確認"
